# Copy this into the mod storage scripts directory as scripts/main.ebsl,
# or paste it through the EBSL Script task inline setting.

start
message "EBSL workflow started"

set loops 0
repeat 3 {
  change loops 1
  jump 4t
  wait 8t
}

if sensor_health_below 8 {
  message "low health, stopping"
  stop_all
} else {
  message "workflow finished"
}

space_mob on closest 3 0.35 32
wait 5s
space_mob off
