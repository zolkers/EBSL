{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useDefineForClassFields": true,
    "rootDir": "src/main/ts",
    "outDir": "build/compiled-js",
    "lib": [
      "DOM",
      "ES2022"
    ]
  },
  "include": [
    "src/main/ts/**/*.ts"
  ]
}
