{
	"schemaVersion": 1,
	"id": "${mod_id}",
	"version": "${version}",
	"name": "${mod_name}",
	"description": "${mod_description}",
	"authors": [
		"${mod_authors}"
	],
	"contact": {
		"homepage": "${mod_homepage}",
		"sources": "${mod_sources}"
	},
	"license": "${mod_license}",
	"icon": "assets/${mod_id}/icon.png",
	"environment": "${mod_environment}",
	"entrypoints": {
		"client": [
			"fr.riege.ebsl.fabric.FabricEbslMod"
		]
	},
	"mixins": [
		"ebsl.loader.mixins.json"
	],
	"depends": {
		"fabricloader": ">=${loader_version}",
		"minecraft": "~${minecraft_version}",
		"java": ">=${minecraft_java_version}",
		"fabric-api": "*",
		"fabric-gui-imgui": "*"
	}
}
