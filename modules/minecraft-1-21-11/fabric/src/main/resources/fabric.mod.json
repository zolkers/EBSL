{
	"schemaVersion": 1,
	"id": "ebsl",
	"version": "${version}",
	"name": "EBSL",
	"description": "Client-side automation and workflow tooling for pathfinding, overlays, and scriptable Minecraft tasks.",
	"authors": [
		"Victor Riegert"
	],
	"contact": {
		"homepage": "https://github.com/zolkers/EBSL",
		"sources": "https://github.com/zolkers/EBSL"
	},
	"license": "GPL-3.0-or-later",
	"icon": "assets/ebsl/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"fr.riege.ebsl.fabric.FabricEbslMod"
		]
	},
	"mixins": [
		"ebsl.loader.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-gui-imgui": "*"
	}
}
